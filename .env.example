# MedAI Compass Environment Configuration
# Copy this file to .env and fill in the values
# Run: python scripts/generate_secrets.py to auto-generate secrets

# =============================================================================
# Database (PostgreSQL)
# =============================================================================
POSTGRES_HOST="localhost"
POSTGRES_PORT="5432"
POSTGRES_USER="medai"
POSTGRES_PASSWORD=""  # Auto-generated
POSTGRES_DB="medai_compass"

# =============================================================================
# Redis (Cache & Queues)
# =============================================================================
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD=""  # Auto-generated

# =============================================================================
# Security
# =============================================================================
JWT_SECRET=""  # Auto-generated (64 hex chars)
PHI_ENCRYPTION_KEY=""  # Auto-generated (Fernet key for HIPAA PHI encryption)

# =============================================================================
# API Configuration
# =============================================================================
API_HOST="0.0.0.0"
API_PORT="8000"
CORS_ORIGINS="*"  # Set specific origins in production
ENVIRONMENT="development"  # development, staging, production
LOG_LEVEL="INFO"
DEBUG="false"

# =============================================================================
# HuggingFace (Required for MedGemma models)
# =============================================================================
# Get token from: https://huggingface.co/settings/tokens
# Ensure you have accepted the MedGemma license
HF_TOKEN=""
HUGGING_FACE_HUB_TOKEN=""  # Alternative name

# =============================================================================
# Modal (Cloud GPU - Recommended for macOS/no local GPU)
# =============================================================================
# Get tokens by running: modal token new
MODAL_TOKEN_ID=""
MODAL_TOKEN_SECRET=""

# =============================================================================
# Object Storage (MinIO)
# =============================================================================
MINIO_ENDPOINT="localhost:9000"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY=""  # Set a secure value in production

# =============================================================================
# Monitoring
# =============================================================================
GRAFANA_PASSWORD="admin"  # Change in production

# =============================================================================
# Dataset Access (Optional)
# =============================================================================
# PhysioNet credentials for MIMIC datasets
# Register at: https://physionet.org/
PHYSIONET_USERNAME=""
PHYSIONET_PASSWORD=""

# =============================================================================
# TLS/HTTPS (Production)
# =============================================================================
# Domain for Let's Encrypt certificates
DOMAIN=""
ACME_EMAIL=""
