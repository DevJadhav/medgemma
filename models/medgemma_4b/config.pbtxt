# MedGemma 4B Triton Configuration
# Primary diagnostic imaging model

name: "medgemma_4b"
platform: "vllm"
max_batch_size: 4

# Model versioning
version_policy: { latest: { num_versions: 2 }}

# Input configuration
input [
  {
    name: "text_input"
    data_type: TYPE_STRING
    dims: [ -1 ]  # Variable length text
  },
  {
    name: "image_input"
    data_type: TYPE_FP32
    dims: [ -1, 3, 224, 224 ]  # NCHW format, variable batch
    optional: true
  },
  {
    name: "max_tokens"
    data_type: TYPE_INT32
    dims: [ 1 ]
    optional: true
  },
  {
    name: "temperature"
    data_type: TYPE_FP32
    dims: [ 1 ]
    optional: true
  }
]

# Output configuration
output [
  {
    name: "text_output"
    data_type: TYPE_STRING
    dims: [ -1 ]
  },
  {
    name: "logprobs"
    data_type: TYPE_FP32
    dims: [ -1 ]
    optional: true
  }
]

# Dynamic batching for optimal throughput
dynamic_batching {
  preferred_batch_size: [ 1, 2, 4 ]
  max_queue_delay_microseconds: 100000  # 100ms max wait
  preserve_ordering: true
}

# GPU instance configuration
instance_group [
  {
    count: 1
    kind: KIND_GPU
    gpus: [ 0 ]
  }
]

# Model parameters
parameters {
  key: "model_path"
  value: { string_value: "/models/medgemma_4b/1/model" }
}

parameters {
  key: "dtype"
  value: { string_value: "bfloat16" }
}

parameters {
  key: "tensor_parallel_size"
  value: { string_value: "1" }
}

parameters {
  key: "gpu_memory_utilization"
  value: { string_value: "0.85" }
}

parameters {
  key: "max_model_len"
  value: { string_value: "8192" }
}

parameters {
  key: "trust_remote_code"
  value: { string_value: "true" }
}

# Optimization settings
optimization {
  execution_accelerators {
    gpu_execution_accelerator [
      {
        name: "tensorrt"
        parameters { key: "precision_mode" value: "FP16" }
        parameters { key: "max_workspace_size_bytes" value: "4294967296" }
      }
    ]
  }
  
  input_pinned_memory { enable: true }
  output_pinned_memory { enable: true }
}

# Health check configuration
model_warmup [
  {
    name: "warmup_sample"
    count: 1
    inputs {
      key: "text_input"
      value: {
        data_type: TYPE_STRING
        dims: [ 1 ]
        string_data: "Describe this medical image."
      }
    }
  }
]

# Response cache for repeated queries (disabled for HIPAA)
response_cache { enable: false }
